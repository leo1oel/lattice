{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lattice",
  "version": "0.1.66",
  "identifier": "app.leo1oel.researchwriter",
  "build": {
    "beforeDevCommand": "pnpm prepare:agent && pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm prepare:agent && pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lattice",
        "width": 1440,
        "height": 900,
        "minWidth": 1060,
        "minHeight": 680,
        "center": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 16,
          "y": 16
        },
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM1MkFFM0U0NkFFOEM4OTIKUldTU3lPaHE1T01xTlV4dUozZGVvRUhxcVpJREl1aVJsRkpiYVl4aWttcjJseENQTnBLSzI4VzgK",
      "endpoints": [
        "https://github.com/leo1oel/lattice/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/lattice-agent"
    ],
    "resources": [
      "omp-assets/**/*"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "-",
      "entitlements": "Entitlements.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
