{
  "name": "research-writer",
  "private": true,
  "version": "0.1.48",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "prepare:agent": "node scripts/prepare-omp-sidecar.mjs",
    "check": "pnpm lint && pnpm test && pnpm build && cargo test --manifest-path src-tauri/Cargo.toml && cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings",
    "lint": "eslint src",
    "test": "vitest run",
    "preview": "vite preview",
    "tauri": "tauri",
    "collab:dev": "pnpm --dir collab-server run dev",
    "collab:deploy": "pnpm --dir collab-server run deploy",
    "collab:login": "pnpm --dir collab-server run login"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/language": "^6.12.4",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@fontsource/dm-sans": "^5.3.0",
    "@fontsource/instrument-serif": "^5.3.0",
    "@fontsource/jetbrains-mono": "^5.3.0",
    "@lezer/highlight": "^1.2.3",
    "@oh-my-pi/pi-coding-agent": "17.0.5",
    "@replit/codemirror-emacs": "^6.1.0",
    "@replit/codemirror-vim": "^6.3.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "@uiw/react-codemirror": "^4.25.11",
    "codemirror-lang-latex": "^0.4.2",
    "diff": "^9.0.0",
    "dompurify": "^3.4.12",
    "gsap": "^3.15.0",
    "katex": "^0.18.0",
    "lucide-react": "^1.24.0",
    "marked": "^18.0.6",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "y-codemirror.next": "^0.3.5",
    "y-partyserver": "^2.2.0",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/diff": "^8.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "bun": "1.3.14",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "jsdom": "^29.1.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^7.0.4",
    "vitest": "^4.1.10"
  }
}
